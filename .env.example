# ==============================================================================
# Zada Support Agents — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.
# ==============================================================================

# --- Application ---
APP_NAME="AI Customer Service System"
APP_VERSION="1.0.0"
DEBUG=true

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
# Super admin password for /api/super-admin routes (required in production)
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_customer_service

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=  # Set if Qdrant has auth enabled

# --- LLM (Groq) ---
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768

# --- Redis (optional — used for rate limiting + caching) ---
# REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated list of allowed origins for production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- WhatsApp Integration (optional) ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
